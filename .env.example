# Copy this to .env and fill in your values

# --- Core paths (local dev) ---
# All paths are relative to the repo root. Adjust for Docker deploys.
TRACEA_DB_PATH=./data/tracea.db
TRACEA_DATA_DIR=./data
TRACEA_RULES_PATH=./data/detection_rules.yaml
TRACEA_ALERTS_PATH=./data/alerts.yaml

# --- RCA (Root Cause Analysis) backend ---
# Options: disabled, openai, anthropic, ollama
TRACEA_RCA_BACKEND=disabled

# Required for openai backend
# OPENAI_API_KEY=sk-...

# Required for anthropic backend
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model
# TRACEA_RCA_MODEL=gpt-4o

# Optional: custom RCA base URL (for Ollama or proxies)
# TRACEA_RCA_BASE_URL=http://localhost:11434

# Optional: custom RCA prompt template path
# TRACEA_RCA_PROMPT_PATH=/path/to/prompt.txt

# Optional: redact sensitive content before sending to LLM (default: true)
# TRACEA_RCA_REDACT_CONTENT=true

# --- Authentication ---
# Options: disabled, api_key
TRACEA_AUTH_MODE=disabled

# --- Data retention ---
TRACEA_RETENTION_DAYS=30
